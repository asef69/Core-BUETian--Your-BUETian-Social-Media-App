CREATE OR REPLACE FUNCTION get_user_engagement_metrics(p_user_id INTEGER)
RETURNS TABLE(
    total_posts INTEGER,
    total_likes_given INTEGER,
    total_likes_received INTEGER,
    total_comments_given INTEGER,
    total_comments_received INTEGER,
    followers_count INTEGER,
    following_count INTEGER,
    posts_per_day DECIMAL(10,2),
    avg_likes_per_post DECIMAL(10,2),
    engagement_score DECIMAL(10,2)
) AS $$
DECLARE
    user_created_date DATE;
    days_active INTEGER;
BEGIN
    SELECT created_at::DATE INTO user_created_date
    FROM users WHERE id = p_user_id;
    
    days_active := GREATEST(CURRENT_DATE - user_created_date, 1);
    
    RETURN QUERY
    SELECT 
        (SELECT COUNT(*)::INTEGER FROM posts WHERE user_id = p_user_id) as total_posts,
        (SELECT COUNT(*)::INTEGER FROM likes WHERE user_id = p_user_id) as total_likes_given,
        (SELECT COUNT(*)::INTEGER FROM likes l 
         INNER JOIN posts p ON l.post_id = p.id 
         WHERE p.user_id = p_user_id) as total_likes_received,
        (SELECT COUNT(*)::INTEGER FROM comments WHERE user_id = p_user_id) as total_comments_given,
        (SELECT COUNT(*)::INTEGER FROM comments c 
         INNER JOIN posts p ON c.post_id = p.id 
         WHERE p.user_id = p_user_id) as total_comments_received,
        (SELECT COUNT(*)::INTEGER FROM follows 
         WHERE following_id = p_user_id AND status = 'accepted') as followers_count,
        (SELECT COUNT(*)::INTEGER FROM follows 
         WHERE follower_id = p_user_id AND status = 'accepted') as following_count,
        (SELECT COUNT(*)::DECIMAL FROM posts WHERE user_id = p_user_id) / days_active as posts_per_day,
        CASE 
            WHEN (SELECT COUNT(*) FROM posts WHERE user_id = p_user_id) > 0 THEN
                (SELECT COUNT(*)::DECIMAL FROM likes l 
                 INNER JOIN posts p ON l.post_id = p.id 
                 WHERE p.user_id = p_user_id) / 
                (SELECT COUNT(*) FROM posts WHERE user_id = p_user_id)
            ELSE 0 
        END as avg_likes_per_post,
        ((SELECT COUNT(*)::DECIMAL FROM posts WHERE user_id = p_user_id) * 1.0 +
         (SELECT COUNT(*)::DECIMAL FROM likes l 
          INNER JOIN posts p ON l.post_id = p.id 
          WHERE p.user_id = p_user_id) * 0.5 +
         (SELECT COUNT(*)::DECIMAL FROM comments c 
          INNER JOIN posts p ON c.post_id = p.id 
          WHERE p.user_id = p_user_id) * 0.3) as engagement_score;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION can_user_message(
    p_sender_id INTEGER,
    p_receiver_id INTEGER
)
RETURNS BOOLEAN AS $$
DECLARE
    can_message BOOLEAN;
BEGIN
    SELECT EXISTS(
        SELECT 1 FROM follows 
        WHERE follower_id = p_sender_id 
        AND following_id = p_receiver_id 
        AND status = 'accepted'
    ) OR EXISTS(
        SELECT 1 FROM follows 
        WHERE follower_id = p_receiver_id 
        AND following_id = p_sender_id 
        AND status = 'accepted'
    ) OR EXISTS(
        SELECT 1 FROM messages 
        WHERE (sender_id = p_sender_id AND receiver_id = p_receiver_id)
           OR (sender_id = p_receiver_id AND receiver_id = p_sender_id)
    ) INTO can_message;
    
    RETURN can_message;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION get_user_activity_timeline(
    p_user_id INTEGER,
    p_limit INTEGER DEFAULT 20
)
RETURNS TABLE(
    activity_type VARCHAR(20),
    activity_id INTEGER,
    content TEXT,
    created_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    (
        SELECT 
            'post'::VARCHAR(20) as activity_type,
            id as activity_id,
            content,
            created_at
        FROM posts
        WHERE user_id = p_user_id
        
        UNION ALL
        
        SELECT 
            'comment'::VARCHAR(20) as activity_type,
            id as activity_id,
            content,
            created_at
        FROM comments
        WHERE user_id = p_user_id
        
        UNION ALL
        
        SELECT 
            'like'::VARCHAR(20) as activity_type,
            l.id as activity_id,
            p.content,
            l.created_at
        FROM likes l
        INNER JOIN posts p ON l.post_id = p.id
        WHERE l.user_id = p_user_id
    )
    ORDER BY created_at DESC
    LIMIT p_limit;
END;
$$ LANGUAGE plpgsql;
