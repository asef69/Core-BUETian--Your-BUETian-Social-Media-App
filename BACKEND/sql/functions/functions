--User Profile
CREATE OR REPLACE FUNCTION get_user_profile(p_user_id INTEGER, p_viewer_id INTEGER DEFAULT NULL)
RETURNS TABLE(
    id INTEGER,
    student_id INTEGER,
    name VARCHAR(50),
    email VARCHAR(100),
    profile_picture VARCHAR(500),
    blood_group VARCHAR(5),
    batch INTEGER,
    hall_name VARCHAR(100),
    hall_attachement VARCHAR(20),
    department_name VARCHAR(100),
    bio TEXT,
    posts_count BIGINT,
    followers_count BIGINT,
    following_count BIGINT,
    is_following BOOLEAN,
    created_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        u.id,
        u.student_id,
        u.name,
        u.email,
        u.profile_picture,
        u.blood_group,
        u.batch,
        u.hall_name,
        u.hall_attachement,
        u.department_name,
        u.bio,
        (SELECT COUNT(*) FROM posts p WHERE p.user_id = u.id) AS posts_count,
        (SELECT COUNT(*) FROM follows f WHERE f.following_id=u.id AND f.status='accepted') AS followers_count,
        (SELECT COUNT(*) FROM follows f WHERE f.follower_id=u.id AND f.status='accepted') AS following_count,
        CASE 
            WHEN p_viewer_id IS NOT NULL AND p_viewer_id != p_user_id THEN 
                EXISTS(SELECT 1 FROM follows f WHERE f.follower_id = p_viewer_id AND f.following_id = p_user_id AND f.status = 'accepted')
            ELSE FALSE 
        END as is_following,
        u.created_at
    FROM users u
    WHERE u.id = p_user_id AND u.is_active = TRUE;
END;
$$ LANGUAGE plpgsql;

--follow check
CREATE OR REPLACE FUNCTION is_following(p_follower_id INTEGER,p_following_id INTEGER)
RETURNS BOOLEAN AS $$
DECLARE 
    follow_exists BOOLEAN;
BEGIN
    SELECT EXISTS (
        SELECT 1 FROM follows
        WHERE follower_id=p_follower_id 
          AND following_id=p_following_id 
          AND status='accepted'
    ) INTO follow_exists;
    RETURN follow_exists;
END;
$$ LANGUAGE plpgsql;

--mutual followers 
CREATE OR REPLACE FUNCTION  get_mutual_followers(p_user_id INTEGER)
RETURNS TABLE(
    user_id INTEGER,
    name VARCHAR(50),
    profile_picture VARCHAR(500),
    department_name VARCHAR(100)
) AS $$
BEGIN
    RETURN QUERY
    SELECT DISTINCT
        u.id,
        u.name,
        u.profile_picture,
        u.department_name
    FROM users u
    WHERE u.id IN(
        SELECT following_id FROM follows
        WHERE follower_id=p_user_id AND status='accepted'
    )
    AND u.id IN(
        SELECT follower_id FROM follows
        WHERE following_id=p_user_id AND status='accepted'
    )
    AND u.is_active = TRUE;
END;
$$ LANGUAGE plpgsql;

--suggestion user
CREATE OR REPLACE FUNCTION get_suggested_users(p_user_id INTEGER,p_limit INTEGER DEFAULT 10)
RETURNS TABLE(
    id INTEGER,
    name VARCHAR(50),
    profile_picture VARCHAR(500),
    department_name VARCHAR(100),
    batch INTEGER,
    mutual_friends_count BIGINT
) AS $$
DECLARE
    user_dept VARCHAR(100);
    user_batch INTEGER;
BEGIN
    SELECT u_temp.department_name, u_temp.batch INTO user_dept, user_batch
    FROM users u_temp
    WHERE u_temp.id = p_user_id;
    RETURN QUERY
    SELECT
        u.id,
        u.name,
        u.profile_picture,    
        u.department_name,
        u.batch,
        count(DISTINCT mf.following_id) AS mutual_friends_count
    FROM users u
    LEFT JOIN follows mf ON(
        mf.follower_id=p_user_id
        AND mf.status='accepted'
        AND mf.following_id IN(
            SELECT f2.follower_id FROM follows f2
            WHERE f2.following_id=u.id AND f2.status='accepted'
        )
    )
    WHERE u.id!=p_user_id
    AND u.is_active = TRUE
    AND u.id NOT IN(
        SELECT f3.following_id FROM follows f3
        WHERE f3.follower_id=p_user_id 
    )
    AND (u.department_name = user_dept OR u.batch = user_batch)
    GROUP BY u.id,u.name,u.profile_picture,u.department_name,u.batch
    ORDER BY mutual_friends_count DESC,u.batch DESC
    LIMIT p_limit;
END;
$$ LANGUAGE plpgsql;

--POST FUNCTIONS
CREATE OR REPLACE FUNCTION get_user_feed(
    p_user_id INTEGER,
    p_limit INTEGER DEFAULT 20,
    p_offset INTEGER DEFAULT 0
)
RETURNS TABLE(
    post_id INTEGER,
    content TEXT,
    media_type VARCHAR(20),
    visibility VARCHAR(20),
    created_at TIMESTAMP,
    user_id INTEGER,
    user_name VARCHAR(50),
    profile_picture VARCHAR(500),
    likes_count INTEGER,
    comments_count INTEGER,
    is_liked BOOLEAN,
    media_urls JSON
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        p.id as post_id,
        p.content,
        p.media_type,
        p.visibility,
        p.created_at,
        u.id as user_id,
        u.name as user_name,
        u.profile_picture as profile_picture,
        p.likes_count,
        p.comments_count,
        EXISTS(
            SELECT 1 FROM likes l WHERE l.post_id=p.id AND l.user_id=p_user_id
        ) AS is_liked,
        COALESCE(JSON_AGG(JSON_BUILD_OBJECT('media_url', m.media_url, 'media_type', m.media_type)) FILTER (WHERE m.id IS NOT NULL), '[]'::JSON) as media_urls
    FROM posts p
    INNER JOIN users u ON p.user_id=u.id
    LEFT JOIN media_urls m ON p.id = m.post_id
    WHERE (p.group_id IS NULL OR p.group_id = 0)
    AND (
        
        p.user_id=p_user_id
        
        OR (p.user_id IN(
            SELECT f.following_id FROM follows f
            WHERE f.follower_id=p_user_id AND f.status='accepted'
        ) AND (p.visibility='public' OR p.visibility='followers'))
        
        OR (p.visibility='public' AND p.user_id != p_user_id)
    )
    GROUP BY p.id, u.id
    ORDER BY p.created_at DESC
    OFFSET p_offset
    LIMIT p_limit;
END;
$$ LANGUAGE plpgsql;

