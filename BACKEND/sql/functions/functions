CREATE OR REPLACE FUNCTION get_product_details(p_product_id INTEGER)
RETURNS TABLE(
    product_id INTEGER,
    title VARCHAR(250),
    description TEXT,
    price DECIMAL(10,2),
    category VARCHAR(100),
    condition VARCHAR(50),
    location VARCHAR(250),
    status VARCHAR(20),
    seller_id INTEGER,
    seller_name VARCHAR(50),
    seller_picture VARCHAR(500),
    seller_department VARCHAR(100),
    images TEXT[],
    created_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        p.id as product_id,
        p.title,
        p.description,
        p.price,
        p.category,
        p.condition,
        p.location,
        p.status,
        u.id as seller_id,
        u.name as seller_name,
