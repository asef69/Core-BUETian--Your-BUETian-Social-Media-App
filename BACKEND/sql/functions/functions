

--USER FUNCTIONS

--GET USER PROFILE
CREATE OR REPLACE FUNCTION get_user_profile(p_user_id INTEGER)
RETURNS TABLE(
    id INTEGER,
    student_id INTEGER,
    name VARCHAR(50),
    email VARCHAR(100),
    profile_picture VARCHAR(500),
    bio TEXT,
    blood_group VARCHAR(10),
    batch INTEGER,
    hall_name VARCHAR(100),
    hall_attachement VARCHAR(20),
    department_name VARCHAR(100),
    followers_count INTEGER,
    following_count INTEGER,
    posts_count INTEGER,
    created_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    SELECT
        u.id,
        u.student_id,
        u.name,
        u.email,
        u.profile_picture,
        u.bio,
        u.blood_group,
        u.batch,
        u.hall_name,
        u.hall_attachement,
        u.department_name,
        (SELECT COUNT(*) FROM follows f WHERE f.following_id = u.id AND f.status = 'accepted') AS followers_count,
        (SELECT COUNT(*) FROM follows f WHERE f.follower_id = u.id AND f.status = 'accepted') AS following_count,
        (SELECT COUNT(*) FROM posts p WHERE p.user_id = u.id) AS posts_count,
        u.created_at
    FROM users u
    WHERE u.id = p_user_id AND u.is_active = TRUE;
END;
$$ LANGUAGE plpgsql;

--GET PENDING FOLLOW REQUESTS
CREATE OR REPLACE FUNCTION get_pending_follow_requests(p_user_id INTEGER)
RETURNS TABLE(
    follow_id INTEGER,
    follower_id INTEGER,
    follower_name VARCHAR(50),
    follower_picture VARCHAR(500),
    follower_department VARCHAR(100),
    follower_batch INTEGER,
    requested_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    SELECT
        f.id as follow_id,
        f.follower_id,
        u.name as follower_name,
        u.profile_picture as follower_picture,
        u.department_name as follower_department,
        u.batch as follower_batch,
        f.created_at as requested_at
    FROM follows f
    INNER JOIN users u ON f.follower_id = u.id
    WHERE f.following_id = p_user_id
      AND f.status = 'pending'
      AND u.is_active = TRUE
    ORDER BY f.created_at DESC;
END;
$$ LANGUAGE plpgsql;

--REJECT FOLLOW REQUEST
CREATE OR REPLACE FUNCTION reject_follow_request(p_follow_id INTEGER, p_user_id INTEGER)
RETURNS TABLE(reject_follow_request BOOLEAN) AS $$
BEGIN
    DELETE FROM follows
    WHERE id = p_follow_id
      AND following_id = p_user_id
      AND status = 'pending';

    RETURN QUERY SELECT FOUND;
END;
$$ LANGUAGE plpgsql;

--ACCEPT FOLLOW REQUEST
CREATE OR REPLACE FUNCTION accept_follow_request(
    p_follow_id INTEGER,
    p_user_id INTEGER
) RETURNS TABLE(
    follow_id INTEGER,
    follower_id INTEGER,
    following_id INTEGER,
    accepted_at TIMESTAMP
) AS $$
BEGIN
    UPDATE follows
    SET status = 'accepted',
        updated_at = CURRENT_TIMESTAMP
    WHERE id = p_follow_id
      AND following_id = p_user_id
      AND status = 'pending'
    RETURNING id, follower_id, following_id, updated_at AS accepted_at;
END;
$$ LANGUAGE plpgsql;

--mutual followers 
CREATE OR REPLACE FUNCTION  get_mutual_followers(p_user_id INTEGER)
RETURNS TABLE(
    user_id INTEGER,
    name VARCHAR(50),
    profile_picture VARCHAR(500),
    department_name VARCHAR(100)
) AS $$
BEGIN
    RETURN QUERY
    SELECT DISTINCT
        u.id,
        u.name,
        u.profile_picture,
        u.department_name
    FROM users u
    WHERE u.id IN(
        SELECT following_id FROM follows
        WHERE follower_id=p_user_id AND status='accepted'
    )
    AND u.id IN(
        SELECT follower_id FROM follows
        WHERE following_id=p_user_id AND status='accepted'
    )
    AND u.is_active = TRUE;
END;
$$ LANGUAGE plpgsql;



--POST FUNCTIONS

--DETAILS POST
CREATE OR REPLACE FUNCTION get_post_details(p_post_id INTEGER, p_current_user_id INTEGER DEFAULT NULL)
RETURNS TABLE(
    post_id INTEGER,
    content TEXT,
    media_type VARCHAR(20),
    visibility VARCHAR(20),
    created_at TIMESTAMP,
    user_id INTEGER,
    user_name VARCHAR(50),
    profile_picture VARCHAR(500),
    likes_count INTEGER,
    comments_count INTEGER,
    is_liked BOOLEAN,
    media_urls JSON
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        p.id as post_id,
        p.content,
        p.media_type,
        p.visibility,
        p.created_at,
        u.id as user_id,
        u.name as user_name,
        u.profile_picture as profile_picture,
        p.likes_count,
        p.comments_count,
        CASE 
            WHEN p_current_user_id IS NOT NULL THEN 
                EXISTS(SELECT 1 FROM likes l WHERE l.post_id = p.id AND l.user_id = p_current_user_id)
            ELSE FALSE 
        END as is_liked,
        COALESCE(JSON_AGG(JSON_BUILD_OBJECT('media_url', m.media_url, 'media_type', m.media_type)) FILTER (WHERE m.id IS NOT NULL), '[]'::JSON) as media_urls
    FROM posts p
    INNER JOIN users u ON p.user_id = u.id
    LEFT JOIN media_urls m ON p.id = m.post_id
    WHERE p.id = p_post_id
    GROUP BY p.id, u.id;
END;
$$ LANGUAGE plpgsql;

