CREATE OR REPLACE FUNCTION get_user_groups(p_user_id INTEGER)
RETURNS TABLE(
    group_id INTEGER,
    name VARCHAR(100),
    description TEXT,
    cover_image VARCHAR(500),
    role VARCHAR(20),
    members_count BIGINT,
    is_private BOOLEAN,
    joined_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        g.id as group_id,
        g.name,
        g.description,
        g.cover_image,
        gm.role,
        (SELECT COUNT(*) FROM group_members gm2 WHERE gm2.group_id = g.id AND gm2.status = 'accepted') as members_count,
        g.is_private,
        gm.joined_at
    FROM groups g
    INNER JOIN group_members gm ON g.id = gm.group_id
    WHERE gm.user_id = p_user_id 
    AND gm.status = 'accepted'
    ORDER BY gm.joined_at DESC;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION get_suggested_groups(p_user_id INTEGER, p_limit INTEGER DEFAULT 10)
RETURNS TABLE(
    group_id INTEGER,
    name VARCHAR(100),
    description TEXT,
    cover_image VARCHAR(500),
    members_count BIGINT,
    is_private BOOLEAN,
    common_members_count BIGINT
) AS $$
BEGIN
    RETURN QUERY
    WITH connections AS (
        SELECT following_id AS user_id
        FROM follows
        WHERE follower_id = p_user_id AND status = 'accepted'
        UNION
        SELECT follower_id AS user_id
        FROM follows
        WHERE following_id = p_user_id AND status = 'accepted'
    )
    SELECT 
        g.id as group_id,
        g.name,
        g.description,
        g.cover_image,
        (SELECT COUNT(*) FROM group_members gm2 WHERE gm2.group_id = g.id AND gm2.status = 'accepted') as members_count,
        g.is_private,
        (
            SELECT COUNT(*)
            FROM group_members gm1
            WHERE gm1.group_id = g.id
            AND gm1.status = 'accepted'
            AND gm1.user_id IN (SELECT user_id FROM connections)
        ) as common_members_count
    FROM groups g
    WHERE g.id NOT IN (
        SELECT gm2.group_id FROM group_members gm2 WHERE gm2.user_id = p_user_id
    )
    AND g.is_private = FALSE
    ORDER BY common_members_count DESC, members_count DESC
    LIMIT p_limit;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION search_groups(p_search_term VARCHAR(200), p_limit INTEGER DEFAULT 20)
RETURNS TABLE(
    group_id INTEGER,
    name VARCHAR(100),
    description TEXT,
    cover_image VARCHAR(500),
    members_count BIGINT,
    is_private BOOLEAN,
    admin_name VARCHAR(50)
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        g.id as group_id,
        g.name,
        g.description,
        g.cover_image,
        (SELECT COUNT(*) FROM group_members gm2 WHERE gm2.group_id = g.id AND gm2.status = 'accepted') as members_count,
        g.is_private,
        u.name as admin_name
    FROM groups g
    INNER JOIN users u ON g.admin_id = u.id
    WHERE (
        g.name ILIKE '%' || p_search_term || '%' 
        OR g.description ILIKE '%' || p_search_term || '%'
    )
    ORDER BY 
        CASE 
            WHEN g.name ILIKE p_search_term || '%' THEN 1
            WHEN g.name ILIKE '%' || p_search_term || '%' THEN 2
            ELSE 3
        END,
        (SELECT COUNT(*) FROM group_members gm2 WHERE gm2.group_id = g.id AND gm2.status = 'accepted') DESC
    LIMIT p_limit;
END;
$$ LANGUAGE plpgsql;

CREATE OR REPLACE FUNCTION get_group_activity(p_group_id INTEGER, p_days INTEGER DEFAULT 30)
RETURNS TABLE(
    posts_count BIGINT,
    active_members_count BIGINT,
    new_members_count BIGINT,
    total_likes BIGINT,
    total_comments BIGINT
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        (SELECT COUNT(*) FROM posts WHERE group_id = p_group_id AND created_at > CURRENT_DATE - (p_days || ' days')::INTERVAL) as posts_count,
        (SELECT COUNT(DISTINCT user_id) FROM posts WHERE group_id = p_group_id AND created_at > CURRENT_DATE - (p_days || ' days')::INTERVAL) as active_members_count,
        (SELECT COUNT(*) FROM group_members WHERE group_id = p_group_id AND status = 'accepted' AND joined_at > CURRENT_DATE - (p_days || ' days')::INTERVAL) as new_members_count,
        (SELECT COALESCE(SUM(likes_count), 0) FROM posts WHERE group_id = p_group_id AND created_at > CURRENT_DATE - (p_days || ' days')::INTERVAL) as total_likes,
        (SELECT COALESCE(SUM(comments_count), 0) FROM posts WHERE group_id = p_group_id AND created_at > CURRENT_DATE - (p_days || ' days')::INTERVAL) as total_comments;
END;
$$ LANGUAGE plpgsql;



CREATE OR REPLACE FUNCTION get_group_details(p_group_id INTEGER, p_user_id INTEGER DEFAULT NULL)
RETURNS TABLE(
    group_id INTEGER,
    name VARCHAR(100),
    description TEXT,
    admin_id INTEGER,
    admin_name VARCHAR(50),
    is_private BOOLEAN,
    cover_image VARCHAR(500),
    members_count BIGINT,
    posts_count BIGINT,
    is_member BOOLEAN,
    member_status VARCHAR(20),
    created_at TIMESTAMP
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        g.id as group_id,
        g.name,
        g.description,
        g.admin_id,
        u.name as admin_name,
        g.is_private,
        g.cover_image,
        (SELECT COUNT(*) FROM group_members WHERE group_id = g.id AND status = 'accepted') as members_count,
        (SELECT COUNT(*) FROM posts WHERE group_id = g.id) as posts_count,
        CASE 
            WHEN p_user_id IS NOT NULL THEN 
                EXISTS(SELECT 1 FROM group_members WHERE group_id = g.id AND user_id = p_user_id AND status = 'accepted')
            ELSE FALSE 
        END as is_member,
        (SELECT status FROM group_members WHERE group_id = g.id AND user_id = p_user_id) as member_status,
        g.created_at
    FROM groups g
    INNER JOIN users u ON g.admin_id = u.id
    WHERE g.id = p_group_id;
END;
$$ LANGUAGE plpgsql;
