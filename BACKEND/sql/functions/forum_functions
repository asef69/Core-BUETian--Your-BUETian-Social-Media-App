

CREATE OR REPLACE FUNCTION get_tuition_stats_by_subject()
RETURNS TABLE(
    subject_name VARCHAR(100),
    total_posts BIGINT,
    offering_tuition_count BIGINT,
    seeking_tutor_count BIGINT,
    avg_salary DECIMAL(10,2)
) AS $$
BEGIN
    RETURN QUERY
    SELECT 
        tps.subject_name,
        COUNT(*) as total_posts,
        COUNT(*) FILTER (WHERE t.post_type = 'offering_tuition') as offering_tuition_count,
        COUNT(*) FILTER (WHERE t.post_type = 'seeking_tutor') as seeking_tutor_count,
        AVG((t.salary_min + t.salary_max) / 2) as avg_salary
    FROM tution_post_subjects tps
    INNER JOIN tution_posts t ON tps.tution_post_id = t.id
    WHERE t.status = 'active'
    GROUP BY tps.subject_name
    ORDER BY total_posts DESC;
END;
$$ LANGUAGE plpgsql;


    -- Update the status of a blood donation request
    CREATE OR REPLACE FUNCTION update_blood_request_status(
        p_request_id INTEGER,
        p_new_status VARCHAR(20)
    )
    RETURNS TABLE(success BOOLEAN) AS $$
    BEGIN
        UPDATE blood_donation_posts
        SET status = p_new_status, updated_at = CURRENT_TIMESTAMP
        WHERE id = p_request_id;
        RETURN QUERY SELECT FOUND;
    END;
    $$ LANGUAGE plpgsql;


    -- Search active blood requests by hospital location and/or blood group
    CREATE OR REPLACE FUNCTION search_blood_requests_by_location(
        p_location    VARCHAR(255),
        p_blood_group VARCHAR(5)   DEFAULT NULL,
        p_limit       INTEGER DEFAULT 20
    )
    RETURNS TABLE(
        request_id       INTEGER,
        blood_group      VARCHAR(5),
        urgency          VARCHAR(20),
        patient_name     VARCHAR(100),
        hospital_name    VARCHAR(250),
        hospital_address TEXT,
        contact_number   VARCHAR(15),
        needed_date      DATE,
        status           VARCHAR(20),
        created_at       TIMESTAMP,
        requester_name   VARCHAR(50)
    ) AS $$
    BEGIN
        RETURN QUERY
        SELECT
            bd.id AS request_id,
            bd.blood_group,
            bd.urgency,
            bd.patient_name,
            bd.hospital_name,
            bd.hospital_address,
            bd.contact_number,
            bd.needed_date,
            bd.status,
            bd.created_at,
            u.name AS requester_name
        FROM blood_donation_posts bd
        INNER JOIN users u ON u.id = bd.user_id
        WHERE bd.status = 'active'
        AND (bd.hospital_address ILIKE '%' || p_location || '%'
             OR bd.hospital_name ILIKE '%' || p_location || '%')
        AND (p_blood_group IS NULL OR bd.blood_group = p_blood_group)
        ORDER BY
            CASE bd.urgency WHEN 'urgent' THEN 1 WHEN 'moderate' THEN 2 ELSE 3 END,
            bd.created_at DESC
        LIMIT p_limit;
    END;
    $$ LANGUAGE plpgsql;


    -- All blood donation requests posted by a specific user
    CREATE OR REPLACE FUNCTION get_user_blood_requests(p_user_id INTEGER)
    RETURNS TABLE(
        request_id     INTEGER,
        blood_group    VARCHAR(5),
        urgency        VARCHAR(20),
        patient_name   VARCHAR(100),
        hospital_name  VARCHAR(250),
        contact_number VARCHAR(15),
        needed_date    DATE,
        status         VARCHAR(20),
        created_at     TIMESTAMP
    ) AS $$
    BEGIN
        RETURN QUERY
        SELECT
            bd.id AS request_id,
            bd.blood_group,
            bd.urgency,
            bd.patient_name,
            bd.hospital_name,
            bd.contact_number,
            bd.needed_date,
