    -- Search active tuition posts by location, salary range and post type
    CREATE OR REPLACE FUNCTION search_tuition_posts(
        p_location   VARCHAR(255)  DEFAULT NULL,
        p_min_salary DECIMAL(10,2) DEFAULT NULL,
        p_max_salary DECIMAL(10,2) DEFAULT NULL,
        p_post_type  VARCHAR(20)   DEFAULT NULL,
        p_limit      INTEGER DEFAULT 20
    )
    RETURNS TABLE(
        tuition_id     INTEGER,
        post_type      VARCHAR(20),
        subjects       TEXT[],
        class_level    VARCHAR(50),
        location       VARCHAR(250),
        salary_min     DECIMAL(10,2),
        salary_max     DECIMAL(10,2),
        days_per_week  INTEGER,
        contact_number VARCHAR(15),
        status         VARCHAR(20),
        created_at     TIMESTAMP,
        poster_name    VARCHAR(50),
        poster_picture VARCHAR(500)
    ) AS $$
    BEGIN
        RETURN QUERY
        SELECT
            t.id AS tuition_id,
            t.post_type,
            ARRAY(SELECT subject_name FROM tution_post_subjects WHERE tution_post_id = t.id) AS subjects,
            t.class_level,
            t.location,
            t.salary_min,
            t.salary_max,
            t.days_per_week,
            t.contact_number,
            t.status,
            t.created_at,
            u.name AS poster_name,
            u.profile_picture AS poster_picture
        FROM tution_posts t
        INNER JOIN users u ON u.id = t.user_id
        WHERE t.status = 'active'
        AND (p_location IS NULL OR t.location ILIKE '%' || p_location || '%')
        AND (p_min_salary IS NULL OR t.salary_max >= p_min_salary)
        AND (p_max_salary IS NULL OR t.salary_min <= p_max_salary)
        AND (p_post_type IS NULL OR t.post_type = p_post_type)
        ORDER BY t.created_at DESC
        LIMIT p_limit;
    END;
    $$ LANGUAGE plpgsql;


    -- All tuition posts created by a specific user
    CREATE OR REPLACE FUNCTION get_user_tuition_posts(p_user_id INTEGER)
    RETURNS TABLE(
        tuition_id  INTEGER,
        post_type   VARCHAR(20),
        subjects    TEXT[],
        class_level VARCHAR(50),
        location    VARCHAR(250),
        salary_min  DECIMAL(10,2),
        salary_max  DECIMAL(10,2),
        status      VARCHAR(20),
        created_at  TIMESTAMP
    ) AS $$
    BEGIN
        RETURN QUERY
        SELECT
            t.id AS tuition_id,
            t.post_type,
            ARRAY(SELECT subject_name FROM tution_post_subjects WHERE tution_post_id = t.id) AS subjects,
            t.class_level,
            t.location,
            t.salary_min,
            t.salary_max,
            t.status,
            t.created_at
        FROM tution_posts t
        WHERE t.user_id = p_user_id
        ORDER BY t.created_at DESC;
    END;
    $$ LANGUAGE plpgsql;
