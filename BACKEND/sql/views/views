--profile stats
CREATE OR REPLACE VIEW user_profiles_with_stats AS
SELECT 
    u.id,
    u.student_id,
    u.name,
    u.email,
    u.profile_picture,
    u.blood_group,
    u.batch,
    u.hall_name,
    u.hall_attachement,
    u.department_name,
    u.bio,
    u.created_at,
    (SELECT COUNT(*) FROM posts WHERE user_id = u.id) as posts_count,
    (SELECT COUNT(*) FROM follows WHERE following_id = u.id AND status = 'accepted') as followers_count,
    (SELECT COUNT(*) FROM follows WHERE follower_id = u.id AND status = 'accepted') as following_count,
    (SELECT COUNT(*) FROM group_members WHERE user_id = u.id AND status = 'accepted') as groups_count
FROM users u
WHERE u.is_active = TRUE;

--last active
CREATE OR REPLACE VIEW active_users AS
SELECT 
    u.id,
    u.name,
    u.profile_picture,
    u.department_name,
    u.batch,
    MAX(GREATEST(
        COALESCE(p.created_at, '1970-01-01'::timestamp),
        COALESCE(c.created_at, '1970-01-01'::timestamp),
        COALESCE(l.created_at, '1970-01-01'::timestamp)
    )) as last_activity
FROM users u
LEFT JOIN posts p ON u.id = p.user_id
LEFT JOIN comments c ON u.id = c.user_id
LEFT JOIN likes l ON u.id = l.user_id
WHERE u.is_active = TRUE
GROUP BY u.id, u.name, u.profile_picture, u.department_name, u.batch
HAVING MAX(GREATEST(
    COALESCE(p.created_at, '1970-01-01'::timestamp),
    COALESCE(c.created_at, '1970-01-01'::timestamp),
    COALESCE(l.created_at, '1970-01-01'::timestamp)
)) > CURRENT_DATE - INTERVAL '7 days';


--available posts
CREATE OR REPLACE VIEW posts_complete AS
SELECT 
    p.id,
    p.content,
    p.media_type,
    p.visibility,
    p.likes_count,
    p.comments_count,
    p.created_at,
    p.updated_at,
    u.id as author_id,
    u.name as author_name,
    u.profile_picture as author_picture,
    u.department_name as author_department,
    u.batch as author_batch,
    g.id as group_id,
    g.name as group_name,
    (
        SELECT COALESCE(
            JSON_AGG(JSON_BUILD_OBJECT('media_url', mu.media_url, 'media_type', mu.media_type)),
            '[]'::JSON
        )
        FROM media_urls mu
        WHERE mu.post_id = p.id
    ) as media_urls
FROM posts p
INNER JOIN users u ON p.user_id = u.id
LEFT JOIN groups g ON p.group_id = g.id
WHERE u.is_active = TRUE;

-- public viral posts
CREATE OR REPLACE VIEW trending_posts AS
SELECT 
    p.id,
    p.content,
    p.created_at,
    u.name as author_name,
    u.profile_picture as author_picture,
    p.likes_count,
    p.comments_count,
    (p.likes_count + p.comments_count * 2) / 
    (EXTRACT(EPOCH FROM (CURRENT_TIMESTAMP - p.created_at)) / 3600 + 2) as engagement_score
FROM posts p
INNER JOIN users u ON p.user_id = u.id
WHERE p.created_at > CURRENT_TIMESTAMP - INTERVAL '24 hours'
AND p.visibility = 'public'
AND p.group_id IS NULL
ORDER BY engagement_score DESC;

--most public viral
CREATE OR REPLACE VIEW popular_posts AS
SELECT 
    p.id,
    p.content,
    p.media_type,
    p.created_at,
    u.name as author_name,
    u.profile_picture as author_picture,
    p.likes_count,
    p.comments_count
FROM posts p
INNER JOIN users u ON p.user_id = u.id
WHERE p.visibility = 'public'
AND p.group_id IS NULL
ORDER BY p.likes_count DESC, p.comments_count DESC;


-- group stats
CREATE OR REPLACE VIEW groups_with_stats AS
SELECT 
    g.id,
    g.name,
    g.description,
    g.is_private,
    g.cover_image,
    g.created_at,
    u.id as admin_id,
    u.name as admin_name,
    (SELECT COUNT(*) FROM group_members WHERE group_id = g.id AND status = 'accepted') as members_count,
    (SELECT COUNT(*) FROM posts WHERE group_id = g.id) as posts_count
FROM groups g
INNER JOIN users u ON g.admin_id = u.id;

-- group activity
CREATE OR REPLACE VIEW active_groups AS
SELECT 
    g.id,
    g.name,
    g.description,
    g.is_private,
    (SELECT COUNT(*) FROM group_members WHERE group_id = g.id AND status = 'accepted') as members_count,
    (SELECT MAX(created_at) FROM posts WHERE group_id = g.id) as last_post_at
FROM groups g
WHERE EXISTS(
    SELECT 1 FROM posts 
    WHERE group_id = g.id 
    AND created_at > CURRENT_DATE - INTERVAL '30 days'
)
ORDER BY last_post_at DESC;


-- active products
CREATE OR REPLACE VIEW available_products AS
SELECT 
    p.id,
    p.title,
    p.description,
    p.price,
    p.category,
    p.condition,
    p.location,
    p.created_at,
    u.id as seller_id,
    u.name as seller_name,
    u.profile_picture as seller_picture,
    u.department_name as seller_department,
    ARRAY(SELECT image_url FROM marketplace_product_images WHERE product_id = p.id) as images
FROM marketplace_products p
INNER JOIN users u ON p.seller_id = u.id
WHERE p.status = 'available'
AND u.is_active = TRUE
ORDER BY p.created_at DESC;

-- product category
CREATE OR REPLACE VIEW marketplace_category_stats AS
SELECT 
    category,
    COUNT(*) as total_items,
    COUNT(*) FILTER (WHERE status = 'available') as available_items,
    COUNT(*) FILTER (WHERE status = 'sold') as sold_items,
    AVG(price) as avg_price,
    MIN(price) as min_price,
    MAX(price) as max_price
FROM marketplace_products
WHERE category IS NOT NULL
GROUP BY category;

-- blood request
CREATE OR REPLACE VIEW active_blood_requests AS
SELECT 
    bd.id,
    bd.blood_group,
    bd.urgency,
    bd.patient_name,
    bd.hospital_name,
    bd.hospital_address,
    bd.contact_number,
    bd.needed_date,
    bd.description,
    bd.created_at,
    u.name as requester_name,
    u.profile_picture as requester_picture
FROM blood_donation_posts bd
INNER JOIN users u ON bd.user_id = u.id
WHERE bd.status = 'active'
ORDER BY 
    CASE bd.urgency 
        WHEN 'urgent' THEN 1 
        WHEN 'moderate' THEN 2 
        ELSE 3 
    END,
    bd.created_at DESC;

-- tution posts
CREATE OR REPLACE VIEW active_tuition_posts AS
SELECT 
    t.id,
    t.post_type,
    ARRAY(SELECT subject_name FROM tution_post_subjects WHERE tution_post_id = t.id) as subjects,
    t.class_level,
    t.location,
    t.salary_min,
    t.salary_max,
    t.days_per_week,
    t.contact_number,
    t.created_at,
    u.name as poster_name,
    u.profile_picture as poster_picture,
    u.department_name
FROM tution_posts t
INNER JOIN users u ON t.user_id = u.id
WHERE t.status = 'active'
ORDER BY t.created_at DESC;

-- blog publication
CREATE OR REPLACE VIEW published_blogs AS
SELECT 
    b.id,
    b.title,
    b.excerpt,
    b.cover_image,
    b.category,
    ARRAY(SELECT tag_name FROM blog_post_tags WHERE blog_post_id = b.id) as tags,
    b.views_count,
    b.likes_count,
    b.published_at,
    u.name as author_name,
    u.profile_picture as author_picture,
    (SELECT COUNT(*) FROM blog_comments WHERE blog_id = b.id) as comments_count
FROM blog_posts b
INNER JOIN users u ON b.author_id = u.id
WHERE b.is_published = TRUE
ORDER BY b.published_at DESC;

-- notification views
CREATE OR REPLACE VIEW unread_notifications AS
SELECT 
    n.id,
    n.user_id,
    n.notification_type,
    n.reference_id,
    n.content,
    n.created_at,
    u.name as actor_name,
    u.profile_picture as actor_picture
FROM notifications n
INNER JOIN users u ON n.actor_id = u.id
WHERE n.is_read = FALSE
ORDER BY n.created_at DESC;

-- notification history
CREATE OR REPLACE VIEW notification_summary AS
SELECT 
    user_id,
    COUNT(*) as total_notifications,
    COUNT(*) FILTER (WHERE is_read = FALSE) as unread_count,
    COUNT(*) FILTER (WHERE notification_type = 'like') as likes_count,
    COUNT(*) FILTER (WHERE notification_type = 'comment') as comments_count,
    COUNT(*) FILTER (WHERE notification_type = 'follow_request') as follow_requests_count,
    MAX(created_at) as last_notification_at
FROM notifications
GROUP BY user_id;

-- last chat
CREATE OR REPLACE VIEW recent_conversations AS
WITH last_messages AS (
    SELECT DISTINCT ON (
        LEAST(sender_id, receiver_id),
        GREATEST(sender_id, receiver_id)
    )
        id,
        sender_id,
        receiver_id,
        content,
        is_read,
        created_at
    FROM messages
    ORDER BY 
        LEAST(sender_id, receiver_id),
        GREATEST(sender_id, receiver_id),
        created_at DESC
)
SELECT 
    lm.id as message_id,
    lm.sender_id,
    s.name as sender_name,
    s.profile_picture as sender_picture,
    lm.receiver_id,
    r.name as receiver_name,
    r.profile_picture as receiver_picture,
    lm.content as last_message,
    lm.is_read,
    lm.created_at as last_message_time
FROM last_messages lm
INNER JOIN users s ON lm.sender_id = s.id
INNER JOIN users r ON lm.receiver_id = r.id;

-- daily user
CREATE OR REPLACE VIEW daily_user_stats AS
SELECT 
    DATE(created_at) as date,
    COUNT(*) as new_users,
    COUNT(*) FILTER (WHERE is_active = TRUE) as active_users
FROM users
GROUP BY DATE(created_at)
ORDER BY date DESC;

-- posts stats
CREATE OR REPLACE VIEW daily_post_stats AS
SELECT 
    DATE(created_at) as date,
    COUNT(*) as total_posts,
    COUNT(*) FILTER (WHERE media_type != 'text') as posts_with_media,
    SUM(likes_count) as total_likes,
    SUM(comments_count) as total_comments
FROM posts
GROUP BY DATE(created_at)
ORDER BY date DESC;

-- like,comment stats
CREATE OR REPLACE VIEW user_engagement_metrics AS
SELECT 
    u.id,
    u.name,
    u.department_name,
    u.batch,
    (SELECT COUNT(*) FROM posts WHERE user_id = u.id) as posts_count,
    (SELECT COUNT(*) FROM comments WHERE user_id = u.id) as comments_count,
    (SELECT COUNT(*) FROM likes WHERE user_id = u.id) as likes_given,
    (SELECT SUM(p.likes_count) FROM posts p WHERE p.user_id = u.id) as likes_received,
    (SELECT COUNT(*) FROM follows WHERE follower_id = u.id AND status = 'accepted') as following_count,
    (SELECT COUNT(*) FROM follows WHERE following_id = u.id AND status = 'accepted') as followers_count
FROM users u
WHERE u.is_active = TRUE;

-- department stats
CREATE OR REPLACE VIEW department_statistics AS
SELECT 
    department_name,
    COUNT(*) as total_users,
    COUNT(*) FILTER (WHERE is_active = TRUE) as active_users,
    (SELECT COUNT(*) FROM posts p WHERE p.user_id IN (
        SELECT id FROM users WHERE department_name = u.department_name
    )) as total_posts,
    (SELECT COUNT(*) FROM groups g WHERE g.admin_id IN (
        SELECT id FROM users WHERE department_name = u.department_name
    )) as groups_created
FROM users u
WHERE department_name IS NOT NULL
GROUP BY department_name
ORDER BY active_users DESC;

-- batch stats
CREATE OR REPLACE VIEW batch_statistics AS
SELECT 
    batch,
    COUNT(*) as total_students,
    COUNT(*) FILTER (WHERE is_active = TRUE) as active_students,
    COUNT(DISTINCT department_name) as departments_count,
    (SELECT COUNT(*) FROM posts p WHERE p.user_id IN (
        SELECT id FROM users WHERE batch = u.batch
    )) as total_posts
FROM users u
WHERE batch IS NOT NULL
GROUP BY batch
ORDER BY batch DESC;

-- View for table sizes
CREATE OR REPLACE VIEW table_sizes AS
SELECT 
    schemaname as schema,
    tablename as table_name,
    pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename)) as total_size,
    pg_size_pretty(pg_relation_size(schemaname||'.'||tablename)) as table_size,
    pg_size_pretty(pg_total_relation_size(schemaname||'.'||tablename) - pg_relation_size(schemaname||'.'||tablename)) as indexes_size
FROM pg_tables
WHERE schemaname = 'public'
ORDER BY pg_total_relation_size(schemaname||'.'||tablename) DESC;

-- trending content
CREATE MATERIALIZED VIEW IF NOT EXISTS trending_content AS
SELECT 
    'post' as content_type,
    p.id,
    p.content as title,
    u.name as author_name,
    p.likes_count,
    p.comments_count,
    p.created_at,
    (p.likes_count + p.comments_count * 2) / 
    (EXTRACT(EPOCH FROM (CURRENT_TIMESTAMP - p.created_at)) / 3600 + 2) as engagement_score
FROM posts p
INNER JOIN users u ON p.user_id = u.id
WHERE p.created_at > CURRENT_TIMESTAMP - INTERVAL '7 days'
AND p.visibility = 'public'
UNION ALL
SELECT 
    'blog' as content_type,
    b.id,
    b.title,
    u.name as author_name,
    b.likes_count,
    (SELECT COUNT(*) FROM blog_comments WHERE blog_id = b.id)::INTEGER as comments_count,
    b.published_at as created_at,
    (b.likes_count + b.views_count * 0.1) / 
    (EXTRACT(EPOCH FROM (CURRENT_TIMESTAMP - b.published_at)) / 3600 + 2) as engagement_score
FROM blog_posts b
INNER JOIN users u ON b.author_id = u.id
WHERE b.published_at > CURRENT_TIMESTAMP - INTERVAL '7 days'
AND b.is_published = TRUE
ORDER BY engagement_score DESC
LIMIT 50;

-- best trending post index
CREATE INDEX IF NOT EXISTS idx_trending_content_score ON trending_content(engagement_score DESC);

--  user recommendations
CREATE MATERIALIZED VIEW IF NOT EXISTS user_recommendations AS
SELECT DISTINCT
    u1.id as user_id,
    u2.id as recommended_user_id,
    u2.name,
    u2.profile_picture,
    u2.department_name,
    u2.batch,
    COUNT(DISTINCT f2.follower_id) as mutual_friends_count
FROM users u1
CROSS JOIN users u2
LEFT JOIN follows f1 ON f1.follower_id = u1.id AND f1.following_id = u2.id
LEFT JOIN follows mutual1 ON mutual1.follower_id = u1.id AND mutual1.status = 'accepted'
LEFT JOIN follows f2 ON f2.following_id = u2.id 
    AND f2.follower_id = mutual1.following_id 
    AND f2.status = 'accepted'
WHERE u1.id != u2.id
AND u2.is_active = TRUE
AND f1.id IS NULL  
AND (u1.department_name = u2.department_name OR u1.batch = u2.batch)
GROUP BY u1.id, u2.id, u2.name, u2.profile_picture, u2.department_name, u2.batch
HAVING COUNT(DISTINCT f2.follower_id) > 0
ORDER BY u1.id, mutual_friends_count DESC;

