--triggers for data validation or edge cases like as user can't follow themselves and some other edge cases
CREATE OR REPLACE FUNCTION validate_follow()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.follower_id=NEW.following_id THEN
        RAISE EXCEPTION 'A user cannot follow themselves';
    END IF;
    RETURN NEW;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS before_follow_validation ON follows;
CREATE TRIGGER before_follow_validation
    BEFORE INSERT OR UPDATE ON follows
    FOR EACH ROW
    EXECUTE FUNCTION validate_follow();

CREATE OR REPLACE FUNCTION set_user_defaults()
RETURNS TRIGGER AS $$
BEGIN
    IF NEW.is_active IS NULL THEN
        NEW.is_active = TRUE;
    END IF;
    RETURN NEW;
END;    
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS before_user_insert_defaults ON users;
CREATE TRIGGER before_user_insert_defaults
    BEFORE INSERT ON users
    FOR EACH ROW
    EXECUTE FUNCTION set_user_defaults();

CREATE OR REPLACE FUNCTION cleanup_user_data()
RETURNS TRIGGER AS $$
BEGIN
    DELETE FROM notifications WHERE user_id = OLD.id OR actor_id = OLD.id;
    
    UPDATE messages 
    SET content = '[Message from deleted user]' 
    WHERE sender_id = OLD.id;
    
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;

DROP TRIGGER IF EXISTS before_user_delete_cleanup ON users;
CREATE TRIGGER before_user_delete_cleanup
    BEFORE DELETE ON users
    FOR EACH ROW
    EXECUTE FUNCTION cleanup_user_data();   

CREATE OR REPLACE FUNCTION cleanup_post_data()
RETURNS TRIGGER AS $$
BEGIN
    DELETE FROM notifications 
    WHERE reference_id = OLD.id 
    AND notification_type IN ('like', 'comment');
    
    RETURN OLD;
END;
$$ LANGUAGE plpgsql;     

DROP TRIGGER IF EXISTS before_post_delete_cleanup ON posts;
CREATE TRIGGER before_post_delete_cleanup
    BEFORE DELETE ON posts
    FOR EACH ROW
    EXECUTE FUNCTION cleanup_post_data();


