CREATE INDEX IF NOT EXISTS idx_marketplace_title_fts ON marketplace_products 
    USING gin(to_tsvector('english', title || ' ' || COALESCE(description, '')));
CREATE INDEX IF NOT EXISTS idx_marketplace_available ON marketplace_products(created_at DESC) 
    WHERE status = 'available';

--product image table
CREATE INDEX IF NOT EXISTS idx_marketplace_images_product ON marketplace_product_images(product_id);

--blood donation table
CREATE INDEX IF NOT EXISTS idx_blood_donation_user ON blood_donation_posts(user_id);
CREATE INDEX IF NOT EXISTS idx_blood_donation_blood_group ON blood_donation_posts(blood_group);
