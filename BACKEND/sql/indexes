CREATE INDEX IF NOT EXISTS idx_posts_media_type ON posts(media_type);
CREATE INDEX IF NOT EXISTS idx_posts_created_at ON posts(created_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_updated_at ON posts(updated_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_user_created ON posts(user_id, created_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_group_created ON posts(group_id, created_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_visibility_created ON posts(visibility, created_at DESC);
CREATE INDEX IF NOT EXISTS idx_posts_likes_count ON posts(likes_count DESC);
CREATE INDEX IF NOT EXISTS idx_posts_comments_count ON posts(comments_count DESC);
CREATE INDEX IF NOT EXISTS idx_posts_content_fts ON posts USING gin(to_tsvector('english', content));
CREATE INDEX IF NOT EXISTS idx_posts_public_recent ON posts(created_at DESC) 
    WHERE visibility = 'public' AND group_id IS NULL;

--media urls table
CREATE INDEX IF NOT EXISTS idx_media_urls_post_id ON media_urls(post_id);
CREATE INDEX IF NOT EXISTS idx_media_urls_media_type ON media_urls(media_type);
CREATE INDEX IF NOT EXISTS idx_media_urls_post_type ON media_urls(post_id, media_type);

--comments table
CREATE INDEX IF NOT EXISTS idx_comments_post_id ON comments(post_id);
